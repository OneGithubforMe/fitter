{
  "name": "fitter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node -e \"process.exit(require('fs').existsSync('node_modules/vite/bin/vite.js') ? 0 : 1)\" || npm install vite --no-save",
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "build:pages": "node ./node_modules/vite/bin/vite.js build && node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "deploy": "npm run build:pages && gh-pages -d dist -t true",
    "lint": "eslint .",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.2.0"
  }
}
